<templates xml:space="preserve">
    <t t-name="l10n_ve_igtf.TaxTotalsField" t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <!-- Inyección de IGTF al final del bloque de totales de forma segura y universal -->
        <xpath expr="//table[last()]" position="inside">
            <t t-if="totals.igtf and totals.igtf.apply_igtf">
                <tbody style="border-top: 1px solid #dee2e6;">
                    <!-- IGTF en Bs -->
                    <tr>
                        <td class="o_td_label" style="text-align: right; padding: 2px 8px;">
                            <label class="o_form_label">IGTF <t t-esc="totals.igtf.name"/>:</label>
                        </td>
                        <td style="text-align: right; padding: 2px 8px;">
                            <span t-out="totals.igtf.formatted_igtf_amount"/>
                        </td>
                    </tr>
                    <!-- Total con IGTF -->
                    <tr>
                        <td class="o_td_label" style="text-align: right; padding: 4px 8px;">
                            <label class="o_form_label" style="font-weight: bold;">Total con IGTF:</label>
                        </td>
                        <td style="text-align: right; padding: 4px 8px;">
                            <span t-out="totals.formatted_amount_total_igtf" style="font-weight: bold; font-size: 1.2em;"/>
                        </td>
                    </tr>
                </tbody>
            </t>
        </xpath>
    </t>
</templates>
