<templates xml:space="preserve">
    <!-- En Odoo 18 la lógica de IGTF se maneja vía unified_rows desde el servidor -->
    <t t-name="l10n_ve_igtf.TaxTotalsField" t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <xpath expr="." position="attributes">
            <attribute name="data-igtf-unified">true</attribute>
        </xpath>
    </t>
</templates>
