<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server Action for Client Action (Diagnostic Lab) -->
    <record id="action_pos_fiscal_lab" model="ir.actions.client">
        <field name="name">Fiscal Diagnostic Laboratory</field>
        <field name="tag">pos_fiscal_lab.diagnostic_panel</field>
        <field name="target">main</field>
    </record>

    <!-- Tree View for Commands -->
    <record id="view_pos_fiscal_command_tree" model="ir.ui.view">
        <field name="name">pos.fiscal.command.tree</field>
        <field name="model">pos.fiscal.command</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="protocol"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View for Commands -->
    <record id="view_pos_fiscal_command_form" model="ir.ui.view">
        <field name="name">pos.fiscal.command.form</field>
        <field name="model">pos.fiscal.command</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="protocol"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Dynamic Template">
                            <field name="field_template" placeholder='{"fields": [{"name": "price", "label": "Precio (10d)", "type": "numeric", "length": 10}, ...]}'/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View for Logs -->
    <record id="view_pos_fiscal_log_tree" model="ir.ui.view">
        <field name="name">pos.fiscal.log.tree</field>
        <field name="model">pos.fiscal.log</field>
        <field name="arch" type="xml">
            <list create="false">
                <field name="timestamp"/>
                <field name="command_raw"/>
                <field name="response_raw"/>
                <field name="interpretation"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="action_pos_fiscal_log" model="ir.actions.act_window">
        <field name="name">Communication Logs</field>
        <field name="res_model">pos.fiscal.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Technical Menus -->
    <menuitem id="menu_pos_fiscal_lab_root"
              name="POS Fiscal Laboratory"
              parent="base.menu_custom"
              sequence="100"
              groups="base.group_erp_manager"/>

    <menuitem id="menu_pos_fiscal_lab_action"
              name="Laboratory"
              parent="menu_pos_fiscal_lab_root"
              action="action_pos_fiscal_lab"
              sequence="10"/>

    <menuitem id="menu_pos_fiscal_command_action"
              name="Commands Library"
              parent="menu_pos_fiscal_lab_root"
              action="action_pos_fiscal_command"
              sequence="20"/>

    <menuitem id="menu_pos_fiscal_log_action"
              name="Communication Logs"
              parent="menu_pos_fiscal_lab_root"
              action="action_pos_fiscal_log"
              sequence="30"/>
</odoo>
