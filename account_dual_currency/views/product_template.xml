<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="product_variant_easy_edit_view_dual_currency" model="ir.ui.view">
            <field name="name">product.product.view.form.easy dual currency</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
                    <xpath expr="//field[@name='standard_price']" position="after">
                        <field name="currency_id_dif" invisible="1"/>
                        <field name="standard_price_bs"/>
                    </xpath>
            </field>
        </record>
    
        <record id="product_template_dual_currency_form" model="ir.ui.view">
            <field name="name">product.template.dual_currency</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                    <!-- Ocultar Elementos Nativo y Ruido Visual Pachacutec -->
                    <xpath expr="//field[@name='list_price']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <xpath expr="//field[@name='standard_price']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <xpath expr="//field[@name='uom_po_id']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>
                    <xpath expr="//field[@name='tax_string']" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </xpath>

                    <!-- Campos técnicos ocultos -->
                    <xpath expr="//field[@name='list_price']" position="after">
                        <field name="currency_id_dif" invisible="1"/>
                        <field name="cost_currency_id" invisible="1"/>
                        <field name="uom_name" invisible="1"/>
                        <field name="price_with_tax_bs" invisible="1"/>
                    </xpath>

                    <!-- Inserción de Precisión Pachacutec -->
                    <xpath expr="//field[@name='categ_id']" position="before">
                        <label for="list_price_usd" string="Precio Venta ($)"/>
                        <div class="o_row">
                            <field name="list_price_usd" widget="monetary" options="{'currency_field': 'currency_id_dif'}" class="fw-bold" nolabel="1"/>
                            <span>por</span>
                            <field name="uom_id" position="move" nolabel="1" options="{'no_create': True}" class="oe_inline"/>
                        </div>

                        <field name="price_with_tax_info" string="Impuestos Incl.?" readonly="1" class="text-info small"/>
                        
                        <label for="list_price" string="Precio Venta (Bs.)"/>
                        <div class="o_row">
                            <field name="list_price" readonly="1" force_save="1" options="{'currency_field': 'cost_currency_id'}" widget="monetary" class="text-primary" nolabel="1"/>
                        </div>

                        <field name="taxes_id" position="move" string="Impuestos de Venta?"/>
                        
                        <field name="standard_price" string="Costo ($)?" widget="monetary" options="{'currency_field': 'currency_id_dif'}"/>
                        <field name="standard_price_bs" string="Costo (Bs.)?" readonly="1" options="{'currency_field': 'cost_currency_id'}" widget="monetary"/>
                        
                        <field name="supplier_taxes_id" position="move" string="Impuestos de compra?"/>
                        
                        <field name="costo_reposicion_usd" string="Costo Reposición ($)?" widget="monetary" options="{'currency_field': 'currency_id_dif'}"/>
                    </xpath>

                    <!-- Ajuste de Etiquetas (Afuera del move para evitar ParseError) -->
                    <xpath expr="//field[@name='taxes_id']" position="attributes">
                        <attribute name="string">Impuestos de Venta?</attribute>
                    </xpath>
                    <xpath expr="//field[@name='supplier_taxes_id']" position="attributes">
                        <attribute name="string">Impuestos de compra?</attribute>
                    </xpath>
            </field>
        </record>

        <record id="product_template_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.template.dual_currency_tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='list_price']" position="after">
                    <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field name="currency_id_dif" invisible="1"/>
                    <field name="standard_price_bs" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_template_account_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.template.account.dual_currency_tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="account.product_template_view_tree"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='list_price']" position="after">
                     <field name="currency_id_dif" invisible="1"/>
                     <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_product_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.product.dual_currency_tree</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='lst_price']" position="after">
                    <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field name="currency_id_dif" invisible="1"/>
                    <field name="standard_price_bs" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_template_dual_currency_kanban" model="ir.ui.view">
            <field name="name">product.template.dual_currency_kanban</field>
            <field name="model" >product.template</field>
            <field name="inherit_id" ref="product.product_template_kanban_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//kanban" position="inside">
                    <field name="list_price_usd"/>
                     <field name="currency_id_dif" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='list_price']/.." position="after">
                    <div name="product_lst_price_usd" class="mt-1" style="color: red;">
                        <field name="cost_currency_id" invisible="1"/>
                        Precio Alt.: <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}"/>
                    </div>
                </xpath>
            </field>
        </record>



</odoo>
