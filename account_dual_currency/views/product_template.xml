<?xml version="1.0" encoding="UTF-8"?>
<odoo>

        <record id="product_variant_easy_edit_view_dual_currency" model="ir.ui.view">
            <field name="name">product.product.view.form.easy dual currency</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
            <field name="arch" type="xml">
                    <xpath expr="//field[@name='standard_price']" position="after">
                        <field name="currency_id_dif" invisible="1"/>
                        <field name="standard_price_usd"/>
                    </xpath>
            </field>
        </record>
    
        <record id="product_template_dual_currency_form" model="ir.ui.view">
            <field name="name">product.template.dual_currency</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                   <!-- Rediseño Total Pachacutec -->
                   <xpath expr="//label[@for='list_price']" position="attributes">
                       <attribute name="invisible">1</attribute>
                   </xpath>
                   <xpath expr="//div[@name='pricing']" position="attributes">
                       <attribute name="invisible">1</attribute>
                   </xpath>
                   <xpath expr="//label[@for='standard_price']" position="attributes">
                       <attribute name="invisible">1</attribute>
                   </xpath>
                   <xpath expr="//div[@name='standard_price_uom']" position="attributes">
                       <attribute name="invisible">1</attribute>
                   </xpath>

                   <xpath expr="//div[@name='pricing']" position="after">
                        <field name="currency_id_dif" invisible="1"/>
                        <field name="cost_currency_id" invisible="1"/>
                        <group name="master_dollar_config_premium" class="mt-2 mb-2">
                            <group name="group_sales_premium" string="💰 Ventas y Precios (USD Maestro)">
                                <label for="list_price_usd" string="Precio Maestro ($)"/>
                                <div class="o_row">
                                    <field name="list_price_usd" class="oe_inline fw-bold" widget="monetary" options="{'currency_field': 'currency_id_dif'}" />
                                    <span class="text-muted small italic">(Precio Base en Dólares)</span>
                                </div>
                                <label for="list_price_bs" string="Equivalente en Bs."/>
                                <div class="o_row">
                                    <field name="list_price_bs" readonly="1" force_save="1" options="{'currency_field': 'cost_currency_id'}" widget="monetary" class="oe_inline text-primary" />
                                    <span class="text-muted small italic">(Inc. Impuestos)</span>
                                </div>
                                <label for="price_with_tax_info" string="Resumen Informativo"/>
                                <div class="o_row">
                                    <field name="price_with_tax_info" nolabel="1" class="text-info fw-bold w-100" style="font-size: 0.95em;"/>
                                </div>
                                <field name="taxes_id" widget="many2many_tags" context="{'default_type_tax_use':'sale', 'search_default_sale': 1, 'active_test': True}"/>
                            </group>
                            <group name="group_costs_premium" string="📦 Costos e Inversión (USD Maestro)">
                                <label for="standard_price" string="Costo de Compra ($)"/>
                                <div class="o_row">
                                    <field name="standard_price" class="oe_inline fw-bold" widget="monetary" options="{'currency_field': 'currency_id_dif'}" />
                                </div>
                                <label for="standard_price_bs" string="Costo en Bs."/>
                                <div class="o_row">
                                    <field name="standard_price_bs" readonly="1" options="{'currency_field': 'cost_currency_id'}" widget="monetary" class="oe_inline" />
                                </div>
                                <label for="costo_reposicion_usd" string="Costo Reposición ($)"/>
                                <div class="o_row">
                                    <field name="costo_reposicion_usd" widget="monetary" options="{'currency_field': 'currency_id_dif'}" class="oe_inline" />
                                </div>
                            </group>
                        </group>
                   </xpath>
            </field>
        </record>

        <record id="product_template_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.template.dual_currency_tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='list_price']" position="after">
                    <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field name="currency_id_dif" invisible="1"/>
                    <field name="standard_price_usd" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_template_account_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.template.account.dual_currency_tree</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="account.product_template_view_tree"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='list_price']" position="after">
                     <field name="currency_id_dif" invisible="1"/>
                     <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_product_dual_currency_tree" model="ir.ui.view">
            <field name="name">product.product.dual_currency_tree</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//field[@name='lst_price']" position="after">
                    <field name="cost_currency_id" invisible="1"/>
                    <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
                <xpath expr="//field[@name='standard_price']" position="after">
                    <field name="currency_id_dif" invisible="1"/>
                    <field name="standard_price_usd" options="{'currency_field': 'cost_currency_id'}" />
                 </xpath>
            </field>
        </record>

        <record id="product_template_dual_currency_kanban" model="ir.ui.view">
            <field name="name">product.template.dual_currency_kanban</field>
            <field name="model" >product.template</field>
            <field name="inherit_id" ref="product.product_template_kanban_view"/>
            <field name="arch" type="xml">
                 <xpath expr="//kanban" position="inside">
                    <field name="list_price_usd"/>
                     <field name="currency_id_dif" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='list_price']/.." position="after">
                    <div name="product_lst_price_usd" class="mt-1" style="color: red;">
                        <field name="cost_currency_id" invisible="1"/>
                        Precio Alt.: <field name="list_price_usd" widget="monetary" options="{'currency_field': 'cost_currency_id'}"/>
                    </div>
                </xpath>
            </field>
        </record>



</odoo>
