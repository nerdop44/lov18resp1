<templates xml:space="preserve">
    <t t-name="l10n_ve_tax.TaxTotalsField" t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <!-- Inyectamos nuestra tabla unificada al final y ocultamos las originales -->
        <xpath expr="//table[last()]" position="after">
            <table t-if="totals and totals.unified_rows" class="o_tax_totals_unified oe_right oe_subtotal_footer" style="width: auto; min-width: 350px; table-layout: auto; border-spacing: 0; margin-top: 10px;">
                <thead>
                    <tr style="border-bottom: 2px solid #333; color: #444; font-size: 0.8em; text-transform: uppercase;">
                        <th style="text-align: left; padding: 4px 8px; font-weight: 600;">Concepto</th>
                        <th style="text-align: center; padding: 4px 8px; font-weight: 600; min-width: 90px;">Ref. ($)</th>
                        <th style="text-align: right; padding: 4px 8px; font-weight: 600; min-width: 100px;">Monto (Bs.)</th>
                    </tr>
                </thead>
                <tbody style="font-size: 13px;">
                    <t t-foreach="totals.unified_rows" t-as="row" t-key="row_index">
                        <tr t-att-style="row.is_total ? 'font-weight: bold; border-top: 2px solid #222; background-color: #f9f9f9;' : 'border-bottom: 1px solid #eee;'">
                            <td style="padding: 5px 8px; white-space: nowrap;">
                                <span t-esc="row.label"/>
                            </td>
                            <td style="text-align: center; padding: 5px 8px; color: #444;">
                                <t t-out="row.usd"/>
                            </td>
                            <td style="text-align: right; padding: 5px 8px; color: #000;">
                                <t t-out="row.bs"/>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </xpath>

        <!-- Ocultamos las tablas nativas para evitar duplicados -->
        <xpath expr="//table[not(hasclass('o_tax_totals_unified'))]" position="attributes">
            <attribute name="t-if">false</attribute>
            <attribute name="style">display: none !important;</attribute>
        </xpath>
    </t>

    <!-- Neutralización de legado -->
    <t t-name="l10n_ve_tax.TaxForeignTotalsField" owl="1">
    </t>
</templates>
