<templates xml:space="preserve">
    <t t-name="l10n_ve_tax.TaxTotalsField" t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <!-- Reemplazo TOTAL del componente para evitar errores de herencia parcial -->
        <xpath expr="." position="replace">
            <div t-if="totals" class="o_tax_totals_unified" style="width: 100%; font-family: inherit;">
                <table style="width: 100%; border-collapse: collapse; table-layout: fixed; font-size: 13px;">
                    <thead>
                        <tr style="border-bottom: 2px solid #dee2e6; color: #666; font-size: 0.85em; text-transform: uppercase;">
                            <th style="width: 40%; text-align: left; padding: 4px;">Concepto</th>
                            <th style="width: 30%; text-align: center; padding: 4px;">Ref. ($)</th>
                            <th style="width: 30%; text-align: right; padding: 4px;">Monto (Bs.)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="totals.unified_rows || []" t-as="row" t-key="row_index">
                            <tr t-att-style="row.is_total ? 'border-top: 2px solid #2b2b2b; font-weight: bold; background-color: #fcfcfc;' : 'border-bottom: 1px solid #f2f2f2;'">
                                <td style="padding: 6px 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <span t-esc="row.label" t-att-style="row.is_subtotal ? 'font-weight: 500;' : ''"/>
                                </td>
                                <td style="text-align: center; padding: 6px 4px; color: #333;">
                                    <t t-out="row.usd"/>
                                </td>
                                <td style="text-align: right; padding: 6px 4px; color: #000;">
                                    <t t-out="row.bs"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </xpath>
    </t>

    <!-- Limpieza de componentes legados -->
    <t t-name="l10n_ve_tax.TaxForeignTotalsField" owl="1">
    </t>
</templates>
