<templates xml:space="preserve">
    <t t-name="l10n_ve_tax.TaxTotalsField" t-inherit="account.TaxTotalsField" t-inherit-mode="extension" owl="1">
        <!-- Inyección DIRECTA de moneda dual para evitar errores de registro de componentes -->
        <xpath expr="//table[1]" position="before">
            <t t-if="totals">
                <!-- Bloque de Moneda Extranjera (Dólares) -->
                <table class="oe_right oe_subtotal_footer" style="width: 100%; border-collapse: collapse;">
                    <tbody>
                        <!-- Subtotal USD (Base Ref) -->
                        <tr>
                            <td class="o_td_label" style="padding: 2px 8px; text-align: right;">
                                <label class="o_form_label" style="font-weight: normal;">Base Ref.:</label>
                            </td>
                            <td style="padding: 2px 8px; text-align: right; width: 120px;">
                                <span t-out="totals.foreign_formatted_amount_untaxed" style="white-space: nowrap;"/>
                            </td>
                        </tr>
                        
                        <!-- Impuestos USD (Impuesto Ref) -->
                        <t t-foreach="totals.groups_by_foreign_subtotal || {}" t-as="subtotal_name" t-key="subtotal_name">
                           <t t-foreach="totals.groups_by_foreign_subtotal[subtotal_name]" t-as="tax_group" t-key="tax_group.group_key">
                                <tr>
                                    <td class="o_td_label" style="padding: 2px 8px; text-align: right;">
                                        <label class="o_form_label" style="font-weight: normal;" t-esc="'Impuesto Ref. ' + tax_group.tax_group_name + ':'"/>
                                    </td>
                                    <td style="padding: 2px 8px; text-align: right;">
                                        <span t-out="tax_group.formatted_tax_group_amount" style="white-space: nowrap;"/>
                                    </td>
                                </tr>
                           </t>
                        </t>

                        <!-- Total USD (Total Ref) -->
                        <tr style="border-top: 1px solid #dee2e6;">
                            <td class="o_td_label" style="padding: 4px 8px; text-align: right;">
                                <label class="o_form_label" style="font-weight: bold; font-size: 1.1em;">Total Ref.:</label>
                            </td>
                            <td style="padding: 4px 8px; text-align: right;">
                                <span t-out="totals.foreign_formatted_amount_total" style="font-weight: bold; font-size: 1.2em; white-space: nowrap; color: #000;"/>
                            </td>
                        </tr>
                    </tbody>
                </table>
                <div style="border-bottom: 1px solid #dee2e6; margin: 10px 0; width: 100%; float: right;"/>
            </t>
        </xpath>
    </t>
</templates>
