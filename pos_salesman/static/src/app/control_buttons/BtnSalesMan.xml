<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_salesman.BtnSalesMan">
        <button class="control-button btn btn-light rounded-0 fw-bolder" t-on-click="onClick">
            <i class="fa fa-user me-1" role="img" aria-label="Vendedor" title="Vendedor" />
            <span>Vendedor</span>
            <t t-if="salesmanName">
                : <t t-esc="salesmanName"/>
            </t>
        </button>
    </t>

    <t t-name="pos_salesman.ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <BtnSalesMan t-if="!ui.isSmall" />
        </xpath>
        <xpath expr="//div[hasclass('actionpad')]/div[hasclass('d-md-none') or hasclass('d-flex')][1]" position="inside">
            <BtnSalesMan t-if="ui.isSmall" />
        </xpath>
    </t>
</templates>
