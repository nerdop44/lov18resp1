<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_salesman.BtnSalesMan">
        <button class="control-button btn btn-light rounded-0 fw-bolder" t-on-click="onClick">
            <i class="fa fa-user me-1" role="img" aria-label="Vendedor" title="Vendedor" />
            <span>Vendedor</span>
            <t t-if="salesmanName">
                : <t t-esc="salesmanName"/>
            </t>
        </button>
    </t>

    <t t-name="pos_salesman.ActionpadWidget" t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('validation')]" position="before">
            <BtnSalesMan />
        </xpath>
    </t>
</templates>
