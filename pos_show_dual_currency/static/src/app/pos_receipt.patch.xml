<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('receipt-total')]" position="after">
            <div t-if="pos.config.show_dual_currency" class="pos-receipt-amount-dual" style="text-align: right; color: red; font-size: small; border-top: 1px dashed black; padding-top: 5px;">
                Total en Divisa: <t t-esc="pos.getAmountInRefCurrency(props.data.total_with_tax, true)"/>
            </div>
            <div t-if="props.data.x_igtf_amount" class="pos-receipt-igtf" style="text-align: right; font-size: x-small;">
                IGTF (3%): <t t-esc="props.formatCurrency(props.data.x_igtf_amount)"/>
            </div>
            <t t-if="props.data.x_igtf_amount">
                <div class="pos-receipt-amount-total-igtf" style="text-align: right; font-weight: bolder; font-size: 1.2em; border-top: 1px solid black; margin-top: 10px; padding-top: 5px;">
                    TOTAL CON IGTF: <t t-esc="props.formatCurrency(props.data.total_with_igtf)"/>
                </div>
                <div t-if="pos.config.show_dual_currency" class="pos-receipt-amount-dual-igtf" style="text-align: right; color: red; font-weight: bolder; font-size: 1.1em;">
                    Total Divisa (inc. IGTF): <t t-esc="pos.getAmountInRefCurrency(props.data.total_with_igtf, true)"/>
                </div>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('paymentlines')]//span[hasclass('pos-receipt-right-align')]" position="after">
            <t t-if="pos.config.show_dual_currency">
                 <div style="text-align: right; color: red; font-size: x-small;">
                    <t t-esc="pos.getAmountInRefCurrency(line.amount, true)"/>
                 </div>
            </t>
        </xpath>
    </t>
</templates>
