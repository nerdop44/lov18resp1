<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_show_dual_currency.PaymentScreenStatus" t-inherit="point_of_sale.PaymentScreenStatus" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('payment-status-container')]" position="before">
            <div t-if="props.order.x_igtf_amount > 0" class="igtf-totals-summary mb-2 p-2 border-bottom border-2" style="background-color: #fffaf0;">
                <div class="d-flex justify-content-between mb-1 small text-muted">
                    <span>Subtotal Venta:</span>
                    <span>
                        <t t-esc="saleTotal"/> 
                        <t t-if="pos.config.show_dual_currency"> / <span class="text-danger"><t t-esc="saleTotalDivisa"/></span></t>
                    </span>
                </div>
                <div class="d-flex justify-content-between mb-1 small text-muted">
                    <span>IGTF (3%):</span>
                    <span>
                        <t t-esc="igtfAmount"/>
                        <t t-if="pos.config.show_dual_currency"> / <span class="text-danger"><t t-esc="igtfAmountDivisa"/></span></t>
                    </span>
                </div>
                <div class="d-flex justify-content-between border-top pt-2 mt-1">
                    <span class="fw-bolder fs-5 text-uppercase">Total Final:</span>
                    <span class="fw-bolder fs-3 text-end">
                        <t t-esc="totalWithIgtf"/>
                        <t t-if="pos.config.show_dual_currency"><br/><span class="text-danger fs-4"><t t-esc="totalWithIgtfDivisa"/></span></t>
                    </span>
                </div>
            </div>
        </xpath>

        <xpath expr="//div[hasclass('payment-status-remaining')]" position="inside">
             <t t-if="pos.config.show_dual_currency">
                <div class="currency-dual-remaining p-2 mt-2 border rounded shadow-sm" 
                     style="background-color: #fff5f5; border-color: #feb2b2 !important;">
                     <div class="text-muted small fw-bold">Restante (inc. IGTF)</div>
                     <div class="text-danger fs-5 fw-bolder">
                        <t t-esc="remainingWithIgtf"/>
                        <br/>
                        <span class="fs-6"><t t-esc="remainingWithIgtfDivisa"/></span>
                     </div>
                </div>
            </t>
        </xpath>

        <xpath expr="//div[hasclass('payment-status-change')]" position="inside">
             <t t-if="pos.config.show_dual_currency">
                <div class="currency-dual-change p-2 mt-2 border rounded shadow-sm" 
                     style="background-color: #f0fff4; border-color: #9ae6b4 !important;">
                     <div class="text-muted small fw-bold">Vuelto en Divisa</div>
                     <div class="text-success fs-5 fw-bolder">
                        <t t-esc="pos.getAmountInRefCurrency(props.order.get_change(), true)"/>
                     </div>
                </div>
            </t>
        </xpath>

    </t>
</templates>
